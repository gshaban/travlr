{{> header }}

<main class="content">
  <h1>Travel Packages</h1>
  <p class="intro">
    These sample getaways are loaded from JSON by the Express controller and
    rendered through the Handlebars view.
  </p>

  <section class="trip-grid">
    {{#each trips}}
    <article class="trip-card">
      <img src="/images/{{image}}" alt="{{alt}}">
      <div>
        <h2>{{name}}</h2>
        <p>{{description}}</p>
      </div>
    </article>
    {{/each}}
  </section>
</main>

{{> footer }}