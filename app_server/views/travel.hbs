{{> header }}

<main class="content">
  <h1>Travel Packages</h1>
  <p class="intro">
    These sample getaways are rendered through the Express route, controller,
    and Handlebars view in the MVC structure.
  </p>

  <section class="trip-grid">
    <article class="trip-card">
      <img src="/images/reef1.jpg" alt="Kayaking near a tropical reef">
      <div>
        <h2>Gale Reef</h2>
        <p>
          Enjoy warm water, kayaking, and relaxed beach time at this bright
          island destination.
        </p>
      </div>
    </article>

    <article class="trip-card">
      <img src="/images/reef2.jpg" alt="Travelers walking by an ocean resort">
      <div>
        <h2>Dawson's Reef</h2>
        <p>
          Visit a calm resort area with scenic ocean views and guided day trips.
        </p>
      </div>
    </article>

    <article class="trip-card">
      <img src="/images/reef3.jpg" alt="Tropical beach and blue water">
      <div>
        <h2>Claire's Reef</h2>
        <p>
          Relax beside blue water and plan a quiet vacation with simple
          package options.
        </p>
      </div>
    </article>
  </section>
</main>

{{> footer }}
